{
    "$schema": "https://ai-portal.com/schemas/page-config.json",
    "meta": {
        "key": "llm/models",
        "title": "模型",
        "description": "模型广场",
        "icon": "Shield",
        "api": "/api/integration/pricing?_site=https://pinova.ai/api"
        
    },
    "model": {
        "fields": {
            "id": {
                "label": "ID",
                "type": "text",
                "hidden": true,
                "primaryKey": true
            },
            "model_name": {
                "label": "模型名称",
                "type": "text",
                "validation": {
                    "required": true
                }
            },
            "quota_type": {
                "label": "计费方式",
                "type": "select",
                "options": [
                    {
                        "label": "按量计费",
                        "value": 0
                    },
                    {
                        "label": "按次计费",
                        "value": 1
                    }
                ]
            },
            "description": {
                "label": "描述",
                "type": "textarea"
            },
            "model_price": {
                "label": "固定价格",
                "type": "number"
            },
            "model_ratio": {
                "label": "输入倍率",
                "type": "number"
            },
            "completion_ratio": {
                "label": "输出倍率",
                "type": "number"
            },
            "supported_endpoint_types": {
                "label": "支持的端点类型",
                "type": "text"
            },
            "request_body": {
                "label": "请求参数",
                "type": "text"
            },
            "response_data": {
                "label": "响应结果",
                "type": "text"
            },
            "site_name": {
                "label": "站点",
                "type": "select",
                "options": [
                    {
                        "label": "pinova:8080",
                        "value": "http://20.246.88.31:8080"
                    },
                    {
                        "label": "pinova:8081",
                        "value": "http://20.246.88.31:8081"
                    },
                    {
                        "label": "digitalcloud",
                        "value": "https://www.digitalcloud.asia"
                    }
                ]                
            }
        }
    },
    "views": {
        "search": {
            "fields": [
                {
                    "key": "site_name",
                    "placeholder": "站点名称"
                },
                {
                    "key": "model_name",
                    "placeholder": "模型名称"
                }
            ]
        },
        "table": {
            "size": "small",
            "rownum": true,
            "columns": [
                {
                    "key": "model_name",
                    "width": 150
                },
                {
                    "key": "supported_endpoint_types"
                },
                {
                    "key": "quota_type"
                },
                {
                    "key": "model_price"
                },
                {
                    "key": "model_ratio"
                },
                {
                    "key": "completion_ratio"
                }
            ],
            "actions": {
                "row": [
                    {
                        "action": "showDialog",
                        "title": "详情",
                        "dialogConfig": "llm/viewActionDialog"
                    },
                    {
                        "action": "showDialog",
                        "title": "测试",
                        "dialogConfig": "llm/testActionDialog"                        
                    }
                ],
                "toolbar": [
                ]
            },
            "pagination": {
                "enabled": true,
                "pageSize": 10,
                "mode": "client"
            }
        },
        "form": {
            "layout": "grid",
            "columns": 1,
            "sections": [
                {
                    "title": "模型信息",
                    "fields": [
                        "name",
                        "code",
                        "status",
                        "description"
                    ]
                }
            ]
        }
    }
}