{
    "$schema": "https://ai-portal.com/schemas/page-config.json",
    "meta": {
        "key": "llm/models",
        "title": "模型",
        "description": "模型广场",
        "icon": "Shield",
        "api": "/api/integration/pricing?_site=https://pinova.ai/api"
        
    },
    "model": {
        "fields": {
            "id": {
                "label": "ID",
                "type": "text",
                "hidden": true,
                "primaryKey": true
            },
            "model_name": {
                "label": "模型名称",
                "type": "text",
                "validation": {
                    "required": true
                }
            },
            "quota_type": {
                "label": "计费方式",
                "type": "select",
                "options": [
                    {
                        "label": "按量计费",
                        "value": 0
                    },
                    {
                        "label": "按次计费",
                        "value": 1
                    }
                ]
            },
            "description": {
                "label": "描述",
                "type": "textarea"
            },
            "supported_endpoint_types": {
                "label": "支持的端点类型",
                "type": "text"
            }
        }
    },
    "views": {
        "search": {
            "fields": [
                {
                    "key": "name",
                    "placeholder": "模型名称"
                },
                {
                    "key": "status"
                }
            ]
        },
        "table": {
            "size": "small",
            "rownum": true,
            "columns": [
                {
                    "key": "model_name",
                    "width": 150
                },
                {
                    "key": "supported_endpoint_types"
                },
                {
                    "key": "quota_type"
                },
                {
                    "key": "model_price"
                },
                {
                    "key": "model_ratio"
                },
                {
                    "key": "completion_ratio"
                }
            ],
            "actions": {
                "row": [
                    {
                        "action": "view"
                    }
                ],
                "toolbar": [
                ]
            },
            "pagination": {
                "enabled": true,
                "pageSize": 10,
                "mode": "client"
            }
        },
        "form": {
            "layout": "grid",
            "columns": 1,
            "sections": [
                {
                    "title": "模型信息",
                    "fields": [
                        "name",
                        "code",
                        "status",
                        "description"
                    ]
                }
            ]
        }
    }
}