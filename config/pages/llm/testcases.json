{
    "$schema": "https://ai-portal.com/schemas/page-config.json",
    "meta": {
        "key": "llm/testcases",
        "title": "模型测试用例库",
        "description": "管理和执行模型测试用例",
        "icon": "TestTube",
        "api": "/api/llm/testcases",
        "defaultView": "list"
    },
    "model": {
        "fields": {
            "id": {
                "label": "ID",
                "type": "text",
                "hidden": true,
                "primaryKey": true
            },
            "title": {
                "label": "用例简述",
                "type": "text",
                "validation": { "required": true }
            },
            "model_name": {
                "label": "模型名称",
                "type": "text",
                "validation": { "required": true }
            },
            "endpoint_type": {
                "label": "端点类型",
                "type": "combobox",
                "datasource": "/api/data/valuelist/endpoint"
            },
            "endpoint_url": {
                "label": "端点URL",
                "type": "text",
                "readonly":true
            },
            "site_name": {
                "label": "站点",
                "type": "combobox",
                "datasource": "/api/data/valuelist/sites",
                "labelKey": "label",
                "valueKey": "label",
                "validation": { "required": true }
            },
            "api_token": {
                "label": "API Token",
                "type": "text"
            },
            "request_body": {
                "label": "请求体",
                "type": "json",
                "rows": 10
            },
            "curl_raw": {
                "label": "cURL命令",
                "type": "textarea",
                "rows": 4
            },
            "tags": {
                "label": "标签",
                "type": "text"
            },
            "created_at": {
                "label": "创建时间",
                "type": "text",
                "disabled": true
            }
        }
    },
    "views": {
        "search": {
            "fields": [
                {
                    "key": "model_name",
                    "placeholder": "模型名称"
                },
                {
                    "key": "endpoint_type",
                    "placeholder": "端点类型"
                },
                {
                    "key": "title",
                    "placeholder": "用例名称"
                }
            ]
        },
        "table": {
            "size": "small",
            "rownum": true,
            "columns": [
                {
                    "key": "title",
                    "width": 220
                },
                {
                    "key": "model_name",
                    "width": 160
                },
                {
                    "key": "endpoint_type",
                    "width": 100
                },
                {
                    "key": "tags",
                    "width": 120
                }
            ],
            "actions": {
                "row": [
                    {
                        "action": "edit",
                        "title": "编辑"
                    },
                    {
                        "action": "delete",
                        "title": "删除"
                    }
                ],
                "toolbar": [
                    {
                        "action": "showDialog",
                        "title": "从cURL导入",
                        "dialogConfig": "llm/importCurlDialog"
                    },
                    {
                        "action": "create",
                        "title": "新建"
                    }
                ]
            },
            "pagination": {
                "enabled": true,
                "pageSize": 20,
                "mode": "client"
            }
        },
        "form": {
            "layout": "grid",
            "width": "max-w-4xl",
            "columns": 3,
            "submitButton": {
                "title": "保存",
                "loadingTitle": "保存中..."
            },
            "extraButtons": [
                {
                    "action": "callApi",
                    "title": "生成cURL",
                    "loadingTitle": "生成中...",
                    "api": "/api/llm/testcases/generate-curl",
                    "method": "POST",
                    "bodyFields": ["site_name", "endpoint_url", "api_token", "request_body"],
                    "resultPath": "curl",
                    "copyResult": true,
                    "validateRequired": true,
                    "variant": "outline"
                },
                {
                    "action": "callApi",
                    "title": "测试",
                    "loadingTitle": "测试中...",
                    "api": "/api/llm/testcases/run",
                    "method": "POST",
                    "bodyFields": ["id", "request_body", "site_name", "api_token"],
                    "editOnly": true,
                    "variant": "outline"
                }
            ],
            "sections": [
                {
                    "fields": [
                        { "key": "title", "colSpan": 2 },
                        "tags",
                        "model_name",
                        "endpoint_type",          
                        "endpoint_url",
                        "site_name",
                        { "key": "api_token", "colSpan": 2 },
                        { "key": "request_body", "colSpan": 3 }
                    ]
                }
            ]
        }
    }
}
