{
    "$schema": "https://ai-portal.com/schemas/page-config.json",
    "meta": {
        "key": "llm/testcase",
        "title": "模型测试",
        "description": "模型",
        "icon": "Shield",
        "api": "/api/llm/testcases",
        "defaultView": "form"
    },
    "model": {
        "fields": {
            "id": {
                "label": "ID",
                "type": "text",
                "hidden": true,
                "primaryKey": true
            },
            "site_name": {
                "label": "API站点",
                "type": "combobox",
                "defaultValue":"http://20.246.88.31:8080",
                "datasource": "/api/data/valuelist/sites",
                "validation": {
                    "required": true
                }
            },
            "api_token": {
                "label": "API令牌",
                "type": "text"
            },
            "model_name": {
                "label": "模型名称",
                "type": "combobox",
                "datasource": "/api/integration/pricing?_site=https://pinova.ai/api",
                "validation": {
                    "required": true
                },
                "labelKey": "model_name",
                "valueKey": "model_name",
                "displayFields": [
                    { "key": "model_name", "label": "模型名称", "width": "flex-1" },
                    { "key": "supported_endpoint_types", "label": "端点类型", "width": "w-24" }
                ],
                "fieldMapping": {
                    "supported_endpoint_types": "supported_endpoint_types"
                },
                "onChange": [
                    {
                        "action": "updateJsonField",
                        "target": "request_body",
                        "jsonPath": "model",
                        "value": "{{value}}"
                    }
                ]
            },
            "supported_endpoint_types": {
                "label": "端点类型",
                "type": "text",
                "disabled": true
            },
            "endpoint_type": {
                "label": "端点类型",
                "type": "combobox",
                "datasource": "/api/data/valuelist/endpoint"
            },            
            "endpoint_url": {
                "label": "端点URL",
                "type": "text",
                "disabled": true
            },
            "request_example": {
                "label": "示例",
                "type": "combobox",
                "datasource": "/api/data/valuelist/model_examples?endpoint_url={{endpoint_url}}",
                "fieldMapping": {
                    "request_body": "request_body"
                }
            },   
            "request_body": {
                "label": "请求参数",
                "type": "textarea",
                "rows": 10
            },
            "response_data": {
                "label": "响应结果",
                "type": "textarea",
                "rows": 10
            }
        }
    },
    "views": {
        "search": {
            "fields": [
                {
                    "key": "site_name",
                    "placeholder": "站点名称"
                },
                {
                    "key": "model_name",
                    "placeholder": "模型名称"
                }
            ]
        },
        "table": {
            "size": "small",
            "rownum": true,
            "columns": [
                {
                    "key": "site_name",
                    "width": 150
                },
                {
                    "key": "model_name",
                    "width": 150
                },
                {
                    "key": "endpoint_type"
                }
            ],
            "actions": {
                "row": [],
                "toolbar": []
            },
            "pagination": {
                "enabled": true,
                "pageSize": 10,
                "mode": "client"
            }
        },
        "form": {
            "layout": "grid",
            "columns": 2,
            "submitButton": {
                "title": "开始测试",
                "loadingTitle": "测试中..."
            },
            "extraButtons": [
                { "title": "生成cURL", "action": "generateCurl", "variant": "outline" }
            ],
            "sections": [
                {
                    "title": "站点",
                    "fields": [
                        "site_name",
                        "api_token"
                    ]
                },
                {
                    "title": "模型",
                    "fields": [
                        "model_name",
                        "supported_endpoint_types"
                    ]
                },
                {
                    "title": "请求",
                    "fields": [
                        "endpoint_type",
                        "endpoint_url",
                        { "key": "request_example", "colSpan": 2 },
                        { "key": "request_body", "colSpan": 1 },
                        { "key": "response_data", "colSpan": 1 }
                    ]
                }
            ]
        }
    }
}