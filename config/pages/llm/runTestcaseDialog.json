{
    "title": "执行测试用例",
    "width": "max-w-2xl",
    "sections": [
        {
            "title": "用例信息",
            "columns": 2,
            "fields": [
                "title",
                "model_name",
                "endpoint_type",
                "site_name",
                "endpoint_url"
            ]
        },
        {
            "title": "执行参数",
            "columns": 1,
            "fields": [
                {
                    "key": "api_token",
                    "label": "API Token（留空则使用站点默认）",
                    "editable": true,
                    "type": "text",
                    "placeholder": "如需覆盖站点默认 Token，请在此输入"
                },
                {
                    "key": "request_body",
                    "label": "请求体（可临时修改）",
                    "editable": true,
                    "type": "textarea",
                    "rows": 4
                }
            ]
        }
    ],
    "buttons": [
        {
            "label": "发起调用",
            "api": "/api/llm/testcases/run",
            "method": "POST",
            "bodyFields": ["id", "api_token", "request_body"]
        }
    ]
}
