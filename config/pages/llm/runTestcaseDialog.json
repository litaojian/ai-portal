{
    "title": "执行测试用例",
    "width": "max-w-3xl",
    "sections": [
        {
            "title": "用例信息",
            "columns": 2,
            "fields": [
                "title",
                "model_name",
                "endpoint_type",
                "site_name",
                "endpoint_url"
            ]
        },
        {
            "title": "执行参数",
            "columns": 1,
            "fields": [
                {
                    "key": "api_token_override",
                    "label": "API Token（留空则使用站点默认）",
                    "editable": true,
                    "type": "text",
                    "placeholder": "如需覆盖站点默认 Token，请在此输入"
                },
                {
                    "key": "request_body",
                    "label": "请求体（可临时修改）",
                    "editable": true,
                    "type": "textarea",
                    "rows": 10
                }
            ]
        },
        {
            "title": "执行结果",
            "columns": 1,
            "fields": [
                {
                    "key": "response_data",
                    "label": "响应结果",
                    "editable": false,
                    "type": "textarea",
                    "rows": 10
                }
            ]
        }
    ],
    "buttons": [
        {
            "label": "发起调用",
            "api": "/api/llm/testcases/run",
            "method": "POST",
            "params": {
                "id": "{{id}}",
                "api_token": "{{api_token_override}}",
                "request_body": "{{request_body}}"
            },
            "resultMapping": {
                "response_data": "response_data"
            }
        }
    ]
}
