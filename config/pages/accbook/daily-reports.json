{
    "$schema": "https://ai-portal.com/schemas/page-config.json",
    "meta": {
        "key": "accbook/daily-reports",
        "title": "交易日报",
        "description": "查看每日交易统计报表",
        "icon": "FileText",
        "api": "/api/integration/reports/query"
    },
    "model": {
        "fields": {
            "dataSource": {
                "type": "text",
                "label": "数据源"
            },
            "report_date": {
                "type": "date",
                "label": "日期"
            },
            "user_name": {
                "type": "text",
                "label": "用户"
            },
            "channel_name": {
                "type": "text",
                "label": "渠道"
            },
            "model_name": {
                "type": "text",
                "label": "模型"
            },
            "total_quotas": {
                "label": "消费额度",
                "type": "number",
                "format": "number"
            },
            "total_count": {
                "label": "总请求数",
                "type": "number"
            },
            "total_prompt_tokens": {
                "label": "输入",
                "type": "number"
            },
            "total_completion_tokens": {
                "label": "输出",
                "type": "number"
            },
            "usage_input": {
                "type": "number",
                "label": "输入Usage"
            },
            "usage_output": {
                "type": "number",
                "label": "输出Usage"
            },
            "total_cost": {
                "type": "number",
                "label": "成本"
            },
            "total_amount": {
                "type": "number",
                "label": "收入"
            },
            "currency": {
                "type": "text",
                "label": "币种"
            }
        }
    },
    "views": {
        "search": {
            "fields": [
                {
                    "key": "dateRange",
                    "label": "日期范围",
                    "type": "date-range",
                    "width": "md",
                    "names": [
                        "beginDate",
                        "endDate"
                    ],
                    "defaultValue": [
                        "yesterday",
                        "yesterday"
                    ]
                },
                {
                    "key": "dataSource",
                    "label": "数据源",
                    "type": "select",
                    "required": true,
                    "remoteOptions": {
                        "api": "/api/integration/logs/sources",
                        "labelKey": "name",
                        "valueKey": "name"
                    }
                }
            ]
        },
        "table": {
            "size": "small",
            "rownum": true,
            "columns": [
                {
                    "key": "report_date",
                    "sortable": true
                },
                {
                    "key": "user_name",
                    "sortable": true
                },
                {
                    "key": "channel_name",
                    "sortable": true
                },
                {
                    "key": "model_name",
                    "sortable": true
                },
                {
                    "key": "total_quotas",
                    "sortable": true,
                    "summaryType": "sum"
                },
                {
                    "key": "total_count",
                    "sortable": true,
                    "summaryType": "sum"
                },
                {
                    "key": "total_amount",
                    "sortable": false,
                    "summaryType": "sum"
                },
                {
                    "key": "total_cost",
                    "sortable": true,
                    "summaryType": "sum"
                }
            ],
            "pagination": {
                "enabled": true,
                "pageSize": 50
            }
        }
    }
}